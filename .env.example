# LeadScrape Pro v2.0 Configuration

# Environment
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_PATH=./data/leads.db

# === REQUIRED: At least one scraping API key ===

# Google Places API (Free $200/month credit)
# Get key: https://console.cloud.google.com/apis/credentials
# Enable: "Places API (New)"
GOOGLE_PLACES_API_KEY=

# Yelp Fusion API (Free 5,000 calls/day)
# Get key: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# === OPTIONAL: Email Enrichment (Waterfall) ===

# Hunter.io (25 free searches/month, paid from $34/mo)
# Get key: https://hunter.io/api_keys
HUNTER_API_KEY=

# Apollo.io (50 free credits/month, paid from $49/mo)
# Get key: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# Dropcontact (EU-compliant, paid from €24/mo)
# Get key: https://app.dropcontact.com/app/settings/api
DROPCONTACT_API_KEY=

# === OPTIONAL: Email Verification ===

# ZeroBounce (100 free verifications, paid from $16/mo)
# Get key: https://www.zerobounce.net/members/apikey
ZEROBOUNCE_API_KEY=

# === OPTIONAL: Phone Validation ===

# Twilio Lookup ($0.005/lookup, pay-as-you-go)
# Get credentials: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# === Other Settings ===

# LinkedIn Scraping (Proxycurl)
PROXYCURL_API_KEY=

# Proxy Configuration (for high-volume scraping)
# PROXY_PROVIDER=brightdata
# PROXY_USERNAME=
# PROXY_PASSWORD=

# Scraping Settings
MAX_CONCURRENT_SCRAPERS=2
REQUEST_TIMEOUT_MS=30000

# Export
EXPORT_PATH=./data/exports
