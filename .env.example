# LeadScrape Pro Configuration

# Environment
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_PATH=./data/leads.db

# === REQUIRED: At least one scraping API key ===

# Google Places API (Free $200/month credit)
# Get key: https://console.cloud.google.com/apis/credentials
# Enable: "Places API (New)"
GOOGLE_PLACES_API_KEY=

# Yelp Fusion API (Free 5,000 calls/day)
# Get key: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# === OPTIONAL ===

# Email Enrichment (Hunter.io - 25 free searches/month)
HUNTER_API_KEY=

# LinkedIn Scraping (Proxycurl)
PROXYCURL_API_KEY=

# Proxy Configuration (for high-volume scraping)
# PROXY_PROVIDER=brightdata
# PROXY_USERNAME=
# PROXY_PASSWORD=

# Scraping Settings
MAX_CONCURRENT_SCRAPERS=2
REQUEST_TIMEOUT_MS=30000

# Export
EXPORT_PATH=./data/exports
